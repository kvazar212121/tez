# Standart port: dev-port.json → DEFAULT_PORT (frontend VITE_API_URL bilan bir xil)
PORT=5001

# PostgreSQL Dockerda (loyiha ildizidan: docker compose up -d postgres).
# Hostdan backend: 127.0.0.1 va tashqi port 5433 (compose faylida map qilingan).
# localhost o‘rniga 127.0.0.1 — ba’zi tizimlarda IPv6 (::1) bilan muammo bo‘lmasin.
DATABASE_URL=postgresql://taxi:taxi@127.0.0.1:5433/taxi_free

# Admin panel (JWT). Production: kuchli tasodifiy qiymat.
ADMIN_JWT_SECRET=o‘zgartiring-uzun-tasodifiy-qator
# Birinchi super admin (faqat admin_users bo‘sh bo‘lsa): POST /api/admin/bootstrap
ADMIN_BOOTSTRAP_EMAIL=admin@local.dev
ADMIN_BOOTSTRAP_PASSWORD=admin123ChangeMe
ADMIN_BOOTSTRAP_NAME=Super admin

# Faqat dev: POST /api/admin/dev/reset-admins va UI tugmasi — barcha adminlarni o‘chirish
ADMIN_DEV_RESET=true
